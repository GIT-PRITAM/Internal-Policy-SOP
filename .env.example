# Backend
APP_NAME="Internal Policy & SOP"
APP_ENV=local
APP_KEY=
# Generate with: cd backend && php artisan key:generate --show
APP_DEBUG=true
APP_URL=http://localhost:8080

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# Database (Neon/Postgres)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=internal_policy
DB_USERNAME=internal_policy_user
DB_PASSWORD=internal_policy_pass

# CORS
FRONTEND_URL=http://localhost:3000

# (Render) set these accordingly:
# APP_URL=https://your-render-backend-url
# FRONTEND_URL=https://your-vercel-frontend-url
